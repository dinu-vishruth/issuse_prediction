# Groq API Key for AI analysis
GROQ_API_KEY=your-groq-api-key-here

# JWT Secret for authentication
JWT_SECRET=your-secret-key-change-this-in-production-use-a-long-random-string

# Database URL (for production - PostgreSQL)
# Leave empty for local development (will use SQLite)
# Example for Railway: postgresql://postgres:password@containers-us-west-1.railway.app:5432/railway
DATABASE_URL=
